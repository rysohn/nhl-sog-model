num_vars <- c('l8_sa', 'l4_sog', 'ha_sog', 'l8_sa_ag', 'l4_sog_ag', 'ha_sog_ag', 'blocks_perc', 'blocks_perc_ag', 'is_b2b', 'opp_is_b2b', 'sog_trend', 'sog_ag_trend', 'off_def_gap', 'pace', 'shot_perc', 'shot_perc_ag')
set.seed(42)
train_idx <- createDataPartition(red_train_25_26$true_sog, p=.8, list=F)
train <- red_train_25_26[train_idx, ]
test <- red_train_25_26[-train_idx, ]
scaler <- preProcess(train[, num_vars], method=c('center', 'scale'))
train_scaled <- train
test_scaled <- test
train_scaled[, num_vars] <- predict(scaler, train[, num_vars])
test_scaled[, num_vars] <- predict(scaler, test[, num_vars])
test_scaled2 <- test_scaled
summary(train_scaled[,num_vars])
saveRDS(re_fit, 'nb_sog_model.rds')
saveRDS(scaler, "sog_scaler.rds")
train_data <- train_data_25_26
save(train_data, file = "train_data.RData")
